---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Grazie per il messaggio – Fiori da Indossare"
  description="Messaggio ricevuto! Ti risponderemo presto."
>
  <Navbar />

  <section class="py-24 container mx-auto px-4 text-center max-w-xl">
    <div class="text-6xl mb-6">🌸</div>
    <h1 class="font-slab text-4xl font-semibold mb-4 text-[#5C1A3B]">Grazie!</h1>
    <p class="text-lg text-gray-700 font-light mb-8 leading-relaxed">
      Il tuo messaggio è stato ricevuto. Ti risponderò il prima possibile.
    </p>
    <a
      href="/"
      class="inline-block bg-[#8B7355] hover:bg-[#6b5840] text-white font-bold py-3 px-8 rounded transition"
    >
      Torna alla Home
    </a>
  </section>

  <Footer />
</Layout>
