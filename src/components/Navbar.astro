---
const navLinks = [
  { href: '/bottega', label: 'Bottega' },
  { href: '/contatti', label: 'Contattami' },
];

const currentPath = Astro.url.pathname;
---

<nav class="border-b-2 border-[#E8E1DA] bg-[#FAF8F5] sticky top-0 z-50">
  <div class="container mx-auto px-4 py-3 flex justify-between items-center">
    <a href="/" class="flex items-center space-x-2 hover:opacity-80 transition-opacity">
      <img
        src="/images/logo.png"
        alt="Fiori da Indossare – Logo"
        class="h-10 w-10 object-cover rounded"
        width="40"
        height="40"
      />
      <span class="font-slab font-bold text-xl tracking-wide text-[#4A3B32]">Fiori da Indossare</span>
    </a>

    <!-- Desktop menu -->
    <div class="hidden md:flex text-sm font-bold uppercase text-[#8B7355] space-x-6">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`hover:underline transition ${currentPath === href ? 'underline' : ''}`}
          aria-current={currentPath === href ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden text-[#8B7355] focus:outline-none"
      aria-label="Apri menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-[#E8E1DA] bg-[#FAF8F5]">
    <div class="container mx-auto px-4 py-4 flex flex-col space-y-3 text-sm font-bold uppercase text-[#8B7355]">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`hover:underline transition ${currentPath === href ? 'underline' : ''}`}
          aria-current={currentPath === href ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
