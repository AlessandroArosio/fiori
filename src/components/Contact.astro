---

<section class="contact section" id="contatti" aria-label="Contatti">
  <div class="container">
    <h2 class="section-title">Contatti</h2>
    <hr class="section-divider" />
    <p class="section-subtitle">
      Vieni a trovarci nel nostro negozio a Siracusa o scrivici per informazioni
    </p>

    <div class="contact-grid">
      <div class="contact-info">
        <div class="contact-item">
          <h3>📍 Dove Siamo</h3>
          <address>
            <p>Via Roma, 1</p>
            <p>96100 Siracusa (SR)</p>
            <p>Sicilia, Italia</p>
          </address>
        </div>

        <div class="contact-item">
          <h3>🕐 Orari di Apertura</h3>
          <p>Lunedì – Venerdì: 09:30 – 13:00 / 16:00 – 20:00</p>
          <p>Sabato: 09:30 – 13:00</p>
          <p>Domenica: Chiuso</p>
        </div>

        <div class="contact-item">
          <h3>📞 Contattaci</h3>
          <p>
            Telefono: <a href="tel:+390931000000">+39 0931 000000</a>
          </p>
          <p>
            Email:
            <a href="mailto:info@fioriingioielli.it">info@fioriingioielli.it</a>
          </p>
        </div>
      </div>

      <div class="contact-map">
        <iframe
          title="Mappa Fiori in Gioielli - Siracusa"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3166.123456789!2d15.2866!3d37.0755!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzfCsDA0JzMxLjgiTiAxNcKwMTcnMTEuOCJF!5e0!3m2!1sit!2sit!4v1234567890"
          width="100%"
          height="350"
          style="border:0; border-radius: 4px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background-color: var(--color-bg-alt);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .contact-item {
    margin-bottom: var(--space-lg);
  }

  .contact-item h3 {
    font-size: 1.15rem;
    margin-bottom: var(--space-sm);
    color: var(--color-secondary);
  }

  .contact-item p,
  .contact-item address {
    color: var(--color-text-light);
    line-height: 1.8;
    font-style: normal;
  }

  .contact-item a {
    color: var(--color-primary);
  }

  .contact-item a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
